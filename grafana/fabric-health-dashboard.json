{
  "__inputs": [
    {
      "name": "DS_PROM",
      "label": "Prometheus",
      "description": "The Grafana Cloud Prometheus (Mimir) datasource that receives the fabric-health spine's cron-pushed suxos_* metric snapshot.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "title": "SuxOS — fabric health",
  "uid": "suxos-fabric-health",
  "description": "S1 of the SuxOS v2 fabric-stability spec. Cross-repo pipeline + edge health pushed once per cron tick by the fabric-health spine (.github/.github/workflows/fabric-health.yml) as suxos_* Influx line protocol into Grafana Cloud Prometheus. Lives beside the sux edge dashboards; Cloudflare Workers observability is linked, not rebuilt.",
  "tags": [
    "suxos",
    "fabric",
    "prometheus"
  ],
  "editable": true,
  "schemaVersion": 39,
  "timezone": "",
  "refresh": "5m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "links": [
    {
      "title": "sux — metrics & SLO",
      "type": "dashboards",
      "tags": [
        "sux"
      ],
      "asDropdown": true,
      "targetBlank": false
    },
    {
      "title": "Cloudflare Workers observability",
      "type": "link",
      "url": "https://dash.cloudflare.com/?to=/:account/workers/observability",
      "icon": "external link",
      "targetBlank": true,
      "tooltip": "Worker runtime logs/metrics for sux, suxrouter, sux-fileops (linked, not rebuilt)."
    }
  ],
  "panels": [
    {
      "id": 1,
      "title": "Build backlog (open build-eligible issues, org-wide)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "suxos_pipeline_backlog",
          "legendFormat": "backlog"
        }
      ]
    },
    {
      "id": 2,
      "title": "Stuck & red PRs by repo",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "last_over_time(suxos_pr_stuck_total[20m])",
          "legendFormat": "stuck {{repo}}"
        },
        {
          "refId": "B",
          "expr": "last_over_time(suxos_pr_red_total[20m])",
          "legendFormat": "red {{repo}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Drain-to-zero streak (DoD: 7-day green)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "NOT MET",
                  "color": "red"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "7-DAY STREAK",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "min_over_time(suxos_backlog_zero[7d])"
        }
      ]
    },
    {
      "id": 4,
      "title": "Backlog now",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "last_over_time(suxos_pipeline_backlog[20m])"
        }
      ]
    },
    {
      "id": 5,
      "title": "Workflows red (last run)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(last_over_time(suxos_workflow_red_total[20m])) and on() (min(last_over_time(suxos_collection_ok{collector=\"runs\"}[20m])) == 1)"
        }
      ]
    },
    {
      "id": 6,
      "title": "Budget throttle active",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "clear",
                  "color": "green"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "THROTTLED",
                  "color": "yellow"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "last_over_time(suxos_budget_throttle_active[20m])"
        }
      ]
    },
    {
      "id": 7,
      "title": "Workflows red by repo",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (repo) (last_over_time(suxos_workflow_red_total[20m])) and on(repo) (min by (repo) (last_over_time(suxos_collection_ok{collector=\"runs\"}[20m])) == 1)",
          "legendFormat": "{{repo}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Edge deploy OK by service",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "up",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "last_over_time(suxos_edge_deploy_ok[20m])",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Disabled workflows by repo (non-exempt disabled_manually)",
      "type": "timeseries",
      "description": "A manual disable that isn't one of the workflow_call-only reusable definitions in .github — the class caught by manual audit (docs/design/2026-07-16-suxos-vx-next-arc.md §6, ledger R9).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (repo, workflow) (last_over_time(suxos_workflow_disabled[20m])) and on(repo) (min by (repo) (last_over_time(suxos_collection_ok{collector=\"workflows\"}[20m])) == 1)",
          "legendFormat": "{{repo}}/{{workflow}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Disabled workflow expiry (>48h persisted, non-exempt)",
      "description": "Time-span coverage, not a sample count (#315): fires when the oldest sample of suxos_workflow_disabled visible in the lookback window is >=48h (172800s) older than the newest, i.e. the disable SPANS 48h of wall-clock, rather than requiring an exact count of scrapes (count_over_time >= N) that a multi-hour collector outage could silently drop below. The subquery window is deliberately WIDER than the threshold ([49h] vs 48h, #320): a left-open [48h:...] range can only see samples strictly newer than now-48h, so the measured age is structurally < 48h and the alert could never fire — the extra hour of headroom lets a genuinely-spanning disable clear 48h reliably despite scrape jitter/step alignment. The collector only emits a sample while a workflow is disabled, so an absent-when-healthy series still means the alert clears the moment a workflow is re-enabled; tolerant of any number of missed scrapes as long as the first and last still straddle 48h.",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 30
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "clear",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count((timestamp(suxos_workflow_disabled) - min_over_time(timestamp(suxos_workflow_disabled)[49h:15m])) >= 172800 and on(repo) (min by (repo) (last_over_time(suxos_collection_ok{collector=\"workflows\"}[49h])) == 1)) or vector(0)"
        }
      ]
    },
    {
      "id": 11,
      "title": "Collection integrity (all collectors reporting)",
      "description": "collection-integrity contract (#305): min over every suxos_collection_ok{repo,collector} series. 1 = every collector's query succeeded this tick; 0 (DEGRADED) = at least one collector (issues/prs/runs/workflows on some repo) ERRORED, so the derived signals it feeds are UNKNOWN, not healthy — a backlog/red/stuck 0 during DEGRADED means 'couldn't measure', never 'measured clean'. Also gates the drain-to-zero DoD: the spine withholds backlog_zero=1 whenever an issue query fails, so the 7-day streak can't stay green across an unobserved backlog. Drill into 'Collection OK by repo/collector' to see which collector is down.",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 30
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "collecting",
                  "color": "green"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DEGRADED",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "min(last_over_time(suxos_collection_ok[20m]))"
        }
      ]
    },
    {
      "id": 12,
      "title": "Collection OK by repo/collector (0 = query errored → unknown)",
      "description": "Per-repo, per-collector health of the fabric-health spine's OWN data collection (#305). A dip to 0 means that gh query (issues/prs/runs/workflows) failed on that repo this tick; the metric it feeds (backlog, pr_red/stuck, workflow_red) shows a gap rather than a healthy 0 for the same tick.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 36
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "last_over_time(suxos_collection_ok[20m])",
          "legendFormat": "{{repo}}/{{collector}}"
        }
      ]
    }
  ]
}
